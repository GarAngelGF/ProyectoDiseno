@model ProyectoDiseño.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Panel de Administración - El Jardín";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Panel de Control (Administrador)</h1>
        <div>
            <a asp-controller="Insumos" asp-action="Index" class="btn btn-outline-primary me-2">Ver Catálogo Completo</a>
            <a asp-controller="Movimientos" asp-action="RegistrarTransaccion" class="btn btn-primary">Registrar Movimiento</a>
        </div>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-danger mb-4">
        <div class="card-header bg-danger text-white">
            <h5 class="card-title mb-0"><i class="bi bi-bell-fill me-2"></i>Alertas de Stock Crítico (Reabastecimiento Urgente)</h5>
        </div>
        <div class="card-body">
            @if (Model.AlertasStock != null && Model.AlertasStock.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Insumo</th>
                                <th>Existencia Actual</th>
                                <th>Stock Mínimo</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var alerta in Model.AlertasStock)
                            {
                                <tr class="table-danger">
                                    <td class="fw-bold">@alerta.Nombre</td>
                                    <td><span class="badge bg-danger">@alerta.CantidadActual @alerta.UnidadMedida</span></td>
                                    <td>@alerta.StockMinimo @alerta.UnidadMedida</td>
                                    <td class="text-danger fw-bold">Por debajo del mínimo de seguridad</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-success mb-0"><i class="bi bi-shield-check me-2"></i>Todos los insumos se encuentran en niveles óptimos de almacenamiento.</p>
            }
        </div>
    </div>

    <div class="card border-secondary mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="card-title mb-0"><i class="bi bi-box-seam me-2"></i>Existencias en Tiempo Real (Inventario General)</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Nombre del Insumo</th>
                            <th>Unidad de Medida</th>
                            <th>Cantidad Actual</th>
                            <th>Stock de Seguridad</th>
                            <th>Estado</th>
                            </tr>
                    </thead>
                    <tbody>
                        @if (Model.InventarioCompleto != null && Model.InventarioCompleto.Any())
                        {
                            @foreach (var item in Model.InventarioCompleto)
                            {
                                bool bajoStock = item.CantidadActual < item.StockMinimo;
                                <tr>
                                    <td>@item.IdInsumo</td>
                                    <td class="fw-bold">@item.Nombre</td>
                                    <td>@item.UnidadMedida</td>
                                    <td>
                                        <span class="badge @(bajoStock ? "bg-danger" : "bg-success")">
                                            @item.CantidadActual
                                        </span>
                                    </td>
                                    <td>@item.StockMinimo</td>
                                    <td>
                                        @if (bajoStock)
                                        {
                                            <span class="text-danger fw-bold"><i class="bi bi-x-circle-fill me-1"></i> Crítico</span>
                                        }
                                        else
                                        {
                                            <span class="text-success fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Disponible</span>
                                        }
                                    </td>
                                    </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-3">No hay registros cargados en el catálogo de almacén.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card border-primary mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="card-title mb-0"><i class="bi bi-journal-text me-2"></i>Historial de Movimientos (Auditoría de Almacén)</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID Movimiento</th>
                            <th>Tipo de Movimiento</th>
                            <th>Insumo</th>
                            <th>Cantidad</th>
                            <th>Registrado Por (Persona)</th>
                            <th>Fecha y Hora</th>
                            <th>Observaciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.HistorialMovimientos != null && Model.HistorialMovimientos.Any())
                        {
                            @foreach (var movimiento in Model.HistorialMovimientos)
                            {
                                string badgeClase = "bg-secondary";
                                if (movimiento.TipoMovimiento == "Entrada") badgeClase = "bg-success";
                                else if (movimiento.TipoMovimiento == "Consumo") badgeClase = "bg-info text-dark";
                                else if (movimiento.TipoMovimiento == "Merma") badgeClase = "bg-warning text-dark";

                                <tr>
                                    <td>@movimiento.IdMovimiento</td>
                                    <td>
                                        <span class="badge @badgeClase">@movimiento.TipoMovimiento</span>
                                    </td>
                                    <td class="fw-bold">@movimiento.NombreInsumo</td>
                                    <td>@movimiento.Cantidad</td>
                                    <td>@movimiento.NombrePersona</td>
                                    <td>@movimiento.FechaMovimiento.ToString("dd/MM/yyyy hh:mm tt")</td>
                                    <td class="text-muted text-truncate" style="max-width: 200px;">
                                        @(string.IsNullOrEmpty(movimiento.Observaciones) ? "Sin observaciones" : movimiento.Observaciones)
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-3">No se han registrado transacciones o egresos en el sistema todavía.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>