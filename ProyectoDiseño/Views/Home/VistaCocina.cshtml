@model ProyectoDiseño.ViewModels.DashboardViewModel
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Estación de Cocina";
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <div class="bg-warning text-dark rounded p-2 me-3 d-inline-flex align-items-center justify-content-center shadow-sm">
            <i class="bi bi-egg-fried fs-3"></i>
        </div>
        <div>
            <h2 class="mb-0 fw-bold text-dark">Estación de Cocina</h2>
            <p class="text-muted mb-0">Descuento rápido de ingredientes en tiempo real durante el servicio</p>
        </div>
    </div>
    <hr />

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 border-start border-danger border-4" role="alert">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-2">
        @if (Model.InventarioCompleto != null && Model.InventarioCompleto.Any())
        {
            @foreach (var item in Model.InventarioCompleto)
            {
                // Alerta visual local: Si el producto está por debajo de su stock de seguridad, resalta la tarjeta en amarillo sutil
                var esCritico = item.CantidadActual < item.StockMinimo;
                var cardBg = esCritico ? "border-warning bg-warning-subtle" : "border-light bg-light";
                var badgeClass = esCritico ? "bg-danger" : "bg-primary";
                var estadoTexto = esCritico ? "Stock Bajo" : "Disponible";

                <div class="col">
                    <div class="card h-100 shadow-sm border-2 @cardBg transition-card">
                        <div class="card-body d-flex flex-column text-center p-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="badge @badgeClass">@estadoTexto</span>
                                <small class="text-muted">Mín: @item.StockMinimo @item.UnidadMedida</small>
                            </div>

                            <h4 class="card-title text-dark fw-bold mb-3">@item.Nombre</h4>

                            <div class="my-3">
                                <span class="d-block text-muted small text-uppercase fw-bold tracking-wide">Existencia Actual</span>
                                <span class="fs-1 fw-bold text-dark">@item.CantidadActual</span>
                                <span class="fs-5 text-secondary">@item.UnidadMedida</span>
                            </div>

                            <form asp-controller="Movimientos" asp-action="RegistrarEgreso" method="post" class="mt-auto">
                                <input type="hidden" name="idInsumo" value="@item.IdInsumo" />

                                <input type="hidden" name="idPersona" value="@Context.Session.GetInt32("UsuarioId")" />

                                <input type="hidden" name="tipoMovimiento" value="Consumo" />

                                <div class="input-group input-group-lg">
                                    <input type="number" step="0.01" min="0.01" name="cantidadARetirar" class="form-control text-center bg-white border-secondary" placeholder="0.00" required>
                                    <button class="btn btn-dark fw-bold px-3" type="submit" title="Descontar unidades del inventario">
                                        <i class="bi bi-dash-lg"></i> Retirar
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm p-5 text-center bg-light">
                    <i class="bi bi-box-seam text-muted fs-1 mb-3"></i>
                    <h5 class="text-secondary">No hay materias primas o insumos registrados en el almacén.</h5>
                    <p class="text-muted small mb-0">Comunícate con el administrador para alimentar el catálogo inicial.</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Estilo complementario para mejorar la experiencia de interacción táctil en la cocina */
    .transition-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .transition-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    .bg-warning-subtle {
        background-color: #fff3cd !important;
    }
</style>