@model ProyectoDiseño.Models.Insumo

@{
    ViewData["Title"] = "Modificar Insumo";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>Editar Detalles del Insumo
                    </h5>
                </div>
                <div class="card-body p-4 bg-light">
                    <form asp-controller="Insumos" asp-action="Editar" method="post">

                        <input type="hidden" asp-for="IdInsumo" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold small"></div>

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-semibold text-secondary">Nombre del Insumo</label>
                            <input asp-for="Nombre" class="form-control bg-white" required />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="UnidadMedida" class="form-label fw-semibold text-secondary">Unidad de Medida</label>
                            <select asp-for="UnidadMedida" class="form-select bg-white" required>
                                <option value="Kg">Kilogramos (Kg)</option>
                                <option value="Litros">Litros (L)</option>
                                <option value="Piezas">Piezas (pz)</option>
                            </select>
                            <span asp-validation-for="UnidadMedida" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="CantidadActual" class="form-label fw-semibold text-secondary">Existencia Actual</label>
                                <input asp-for="CantidadActual" type="number" step="0.01" class="form-control text-center bg-white-50" readonly />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="StockMinimo" class="form-label fw-semibold text-secondary">Stock Mínimo</label>
                                <input asp-for="StockMinimo" type="number" step="0.01" class="form-control text-center bg-white" required />
                                <span asp-validation-for="StockMinimo" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4 mt-2">
                            <div class="form-check form-switch p-3 bg-white rounded border shadow-sm">
                                <input class="form-check-input ms-0 me-2" type="checkbox" asp-for="Activo" id="switchActivo">
                                <label class="form-check-label fw-bold text-dark" for="switchActivo">Insumo Habilitado</label>
                                <small class="text-muted d-block mt-1">Si se desmarca, el producto sufrirá una baja lógica; se ocultará del inventario operativo pero conservará su historial transaccional.</small>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-controller="Insumos" asp-action="Index" class="btn btn-outline-secondary px-4">
                                Volver al Catálogo
                            </a>
                            <button type="submit" class="btn btn-dark px-4 fw-bold">
                                Guardar Cambios
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}