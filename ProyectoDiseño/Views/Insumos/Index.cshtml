@model IEnumerable<ProyectoDiseño.Models.Insumo>

@{
    ViewData["Title"] = "Catálogo de Insumos - El Jardín";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Catálogo General de Insumos</h1>
        <div>
            <a asp-controller="Home" asp-action="Dashboard" class="btn btn-outline-secondary me-2">Volver al Dashboard</a>
            <a asp-controller="Insumos" asp-action="Crear" class="btn btn-success"><i class="bi bi-plus-circle me-1"></i>Agregar Nuevo Insumo</a>
        </div>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-secondary shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="card-title mb-0"><i class="bi bi-list-task me-2"></i>Insumos Registrados</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Nombre del Insumo</th>
                            <th>Unidad de Medida</th>
                            <th>Cantidad Actual</th>
                            <th>Stock Mínimo</th>
                            <th class="text-center" style="min-width: 380px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                bool bajoStock = item.CantidadActual < item.StockMinimo;
                                <tr>
                                    <td>@item.IdInsumo</td>
                                    <td class="fw-bold">@item.Nombre</td>
                                    <td>@item.UnidadMedida</td>
                                    <td>
                                        <span class="badge @(bajoStock ? "bg-danger" : "bg-success")">
                                            @item.CantidadActual
                                        </span>
                                    </td>
                                    <td>@item.StockMinimo</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center align-items-center gap-2 flex-wrap">

                                            <a asp-controller="Insumos" asp-action="Editar" asp-route-id="@item.IdInsumo" class="btn btn-warning btn-sm">
                                                <i class="bi bi-pencil-square"></i> Editar
                                            </a>

                                            <a asp-controller="Insumos" asp-action="Eliminar" asp-route-id="@item.IdInsumo" class="btn btn-danger btn-sm">
                                                <i class="bi bi-trash"></i> Eliminar
                                            </a>

                                            <form asp-controller="Insumos" asp-action="ClonarInsumo" method="post" class="d-inline-flex align-items-center border p-1 rounded bg-light shadow-sm">
                                                <input type="hidden" name="idInsumoBase" value="@item.IdInsumo" />

                                                <input type="text" name="nuevoNombre" placeholder="Nombre clon" class="form-control form-control-sm me-1" required style="max-width: 120px;" />
                                                <input type="number" name="nuevaCantidad" placeholder="Cant." class="form-control form-control-sm me-1" required min="0" step="0.01" style="max-width: 65px;" />

                                                <button type="submit" class="btn btn-info btn-sm text-white">
                                                    <i class="bi bi-files"></i> Clonar
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No se encontraron insumos cargados en el catálogo.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>