@model ProyectoDiseño.Models.Insumo

@{
    ViewData["Title"] = "Registrar Insumo";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0 fw-bold">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-box-seam me-2" viewBox="0 0 16 16">
                            <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2zm3.564 1.426L5.596 5 8 5.961 14.154 3.5zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.722V6.838L1 4.239v7.923zM7.443.184a1.5 1.5 0 0 1 1.114 0l7.129 2.852A.5.5 0 0 1 16 3.5v8.662a1 1 0 0 1-.629.928l-7.185 2.874a.5.5 0 0 1-.372 0L.63 13.09a1 1 0 0 1-.63-.928V3.5a.5.5 0 0 1 .301-.462z" />
                        </svg>
                        Registrar Nuevo Insumo
                    </h5>
                </div>
                <div class="card-body p-4 bg-light">
                    <form asp-controller="Insumos" asp-action="Crear" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold small"></div>

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-semibold text-secondary">Nombre del Insumo</label>
                            <input asp-for="Nombre" class="form-control bg-white" placeholder="Ej. Tomate Guaje, Queso Manchego" required />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="UnidadMedida" class="form-label fw-semibold text-secondary">Unidad de Medida</label>
                            <select asp-for="UnidadMedida" class="form-select bg-white" required>
                                <option value="" disabled selected>-- Selecciona una unidad --</option>
                                <option value="Kg">Kilogramos (Kg)</option>
                                <option value="Litros">Litros (L)</option>
                                <option value="Piezas">Piezas (pz)</option>
                            </select>
                            <span asp-validation-for="UnidadMedida" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="CantidadActual" class="form-label fw-semibold text-secondary">Cantidad Inicial</label>
                                <input asp-for="CantidadActual" type="number" step="0.01" min="0" class="form-control text-center bg-white" value="0.00" required />
                                <span asp-validation-for="CantidadActual" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="StockMinimo" class="form-label fw-semibold text-secondary">Stock Mínimo</label>
                                <input asp-for="StockMinimo" type="number" step="0.01" class="form-control text-center bg-white" placeholder="0.00" required />
                                <span asp-validation-for="StockMinimo" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="alert alert-secondary py-2 my-3 border-0 rounded-3">
                            <small class="text-muted d-block">
                                <strong>Regla de Negocio (RN-02):</strong> El Stock Mínimo debe ser estrictamente superior a cero para garantizar la ejecución correcta del algoritmo de alertas del sistema.
                            </small>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 me-md-2">
                                Cancelar
                            </a>
                            <button type="submit" class="btn btn-dark px-4 fw-bold">
                                Guardar Insumo
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}